{
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-write --allow-env daemon.ts --gateway=http://localhost:8081 --data-dir=./data",
    "check": "deno check daemon.ts",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "proseWrap": "preserve"
  }
}
